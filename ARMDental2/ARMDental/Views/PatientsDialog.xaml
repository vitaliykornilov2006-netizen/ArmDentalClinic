<Page x:Class="ARMDental.Views.PatientsDialog"
         xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:local="clr-namespace:ARMDental.Views"
         mc:Ignorable="d" 
        d:DesignHeight="850" d:DesignWidth="1200"
        Title="Пациенты — АРМ Стоматологическая клиника"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок страницы -->
        <Border Grid.Row="0" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
            <Grid Margin="20,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="🧍‍♂️🧍‍♀️" FontSize="29" Margin="0,0,12,0" VerticalAlignment="Center"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Пациенты" 
                                   FontSize="24" 
                                   FontWeight="SemiBold" 
                                   Foreground="#2C3E50"/>
                        <TextBlock Text="Управление пациентами стоматологической клиники" 
                                   FontSize="13.5" 
                                   Foreground="#7F8C8D"/>
                    </StackPanel>
                </StackPanel>

                <!-- Кнопки действий -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="btnAddPatient" Background="#c2185b" Foreground="White" Padding="18,9" Margin="0,0,8,0" Click="btnAddPatient_Click">
                        ➕ Новый пациент
                    </Button>
                    <Button x:Name="btnEdit" Background="#f39c12" Foreground="White" Padding="18,9" Margin="0,0,8,0" Click="btnEdit_Click">
                        ✏️ Изменить
                    </Button>
                    <Button x:Name="btnDelete" Background="#e74c3c" Foreground="White" Padding="18,9" Margin="0,0,8,0" Click="btnDelete_Click">
                        🗑 Удалить
                    </Button>
                    <Button x:Name="btnRefresh" 
                            Background="White" 
                            BorderBrush="#BDC3C7"
                            BorderThickness="1"
                            Padding="16,9"
                            Cursor="Hand"
                            FontSize="14"
                            Click="btnRefresh_Click">
                        🔄 Обновить
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Основное содержимое -->
        <Border Grid.Row="1" Background="#F5F7FA" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Панель фильтров -->
                <Border Grid.Row="0" Background="White" CornerRadius="8" 
                        Padding="18" Margin="0,0,0,18"
                        BorderThickness="1" BorderBrush="#E5E7EB">

                    <WrapPanel Orientation="Horizontal">
                        <TextBox x:Name="txtSearch" 
                                 Width="280"
                                 Height="36"
                                 Margin="0,0,15,0"
                                 Padding="12,8"
                                 FontSize="14"
                                 BorderBrush="#D1D5DB"
                                 BorderThickness="1"
                                 Background="White"
                                 VerticalContentAlignment="Center"
                                 TextChanged="txtSearch_TextChanged"/>

                        <Button Content="🔍 Найти" 
                                Width="110" Height="36"
                                Background="#34495E"
                                Foreground="White"
                                BorderThickness="0"/>
                    </WrapPanel>
                </Border>

                <!-- Таблица пациентов -->
                <DataGrid x:Name="dgPatients" 
                          Grid.Row="1"
                          Background="White"
                          RowHeight="52"
                          HeadersVisibility="Column"
                          GridLinesVisibility="None"
                          BorderBrush="#E5E7EB"
                          BorderThickness="1"
                          AutoGenerateColumns="False"
                          IsReadOnly="True" />
            </Grid>
        </Border>

        <!-- Нижняя строка -->
        <Border Grid.Row="2" Background="#7f3667" Height="34">
            <Grid Margin="20,0">
                <TextBlock x:Name="txtCount" 
                           Text="Всего пациентов: 0"
                           Foreground="#F0E6EA"
                           VerticalAlignment="Center"
                           FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Page>
