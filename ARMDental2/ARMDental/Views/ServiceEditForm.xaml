<Window x:Class="ARMDental.Views.ServiceEditForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Услуга"
        Height="450" 
        Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#c2185b" Padding="15" Margin="-20,-20,-20,15">
            <TextBlock x:Name="txtTitle" Text="Новая услуга"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Название услуги *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtName" Height="35" Margin="0,0,0,15" Padding="10,5"/>

            <TextBlock Text="Описание" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtDescription" Height="80" Margin="0,0,0,15" Padding="10,5"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>

            <TextBlock Text="Цена (₽) *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtPrice" Height="35" Margin="0,0,0,15" Padding="10,5"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" 
                    Width="120" Height="35" 
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" 
                    Width="100" Height="35" 
                    Background="#95A5A6" Foreground="White"
                    BorderThickness="0"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
