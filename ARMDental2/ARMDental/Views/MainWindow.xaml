<Window x:Class="ARMDental.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ARMDental.Views"
        mc:Ignorable="d"
        Title="АРМ Стоматологическая клиника" 
        Height="650" 
        Width="1000"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="35"/>
        </Grid.RowDefinitions>

        <!-- ==================== БОКОВОЕ МЕНЮ ==================== -->
        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="0" Background="#c2185b">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <StackPanel Name="MyStackPanel" Grid.Row="0">

                    <!-- Логотип / Заголовок -->
                    <Border Background="#880e4f" Padding="15">
                        <StackPanel>
                            <TextBlock Text="🦷 АРМ Стоматологическая клиника"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   FontSize="18" 
                                   FontWeight="Bold" 
                                   Foreground="White"
                                   HorizontalAlignment="Center"/>
                            <TextBlock x:Name="txtUserName" 
                                   Text="Иванов Иван" 
                                   FontSize="11" 
                                   Foreground="#F0F8FF"
                                   HorizontalAlignment="Center"
                                   Margin="0,5,0,0"/>
                            <TextBlock x:Name="txtUserRole" 
                                   Text="Администратор" 
                                   FontSize="10" 
                                   Foreground="#F1C40F"
                                   HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>

                    <!-- Пункт меню -->
                    <Button x:Name="btnPatients" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnPatients_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🧍‍♂️🧍‍♀️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Пациенты" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <!-- Пункт меню -->
                    <Button x:Name="btnDoctors" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnDoctors_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👩‍⚕️" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Доктора" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnServices" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnServices_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🦷" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Услуги" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnDiagnoses" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnDiagnoses_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💊" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Диагнозы" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <!-- Пункт меню -->
                    <Button x:Name="btnVisit" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnVisit_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Приём" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="btnPayment" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnPayment_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💸" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Оплата" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="btnReports" 
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand"
                        Padding="15,12"
                        HorizontalAlignment="Stretch" Click="btnReports_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📊" FontSize="16" Margin="0,0,10,0"/>
                            <TextBlock Text="Отчёты" FontSize="14" Foreground="White"/>
                        </StackPanel>
                    </Button>
                    <!-- Разделитель -->
                    <Separator Background="#34495E" Margin="15,10,15,10"/>


                    <!-- Административное меню (видно только админу) -->
                    <StackPanel x:Name="adminMenuPanel">

                        <TextBlock Text="⚙️ АДМИНИСТРИРОВАНИЕ" 
                               Foreground="#E5E4E2" 
                               FontSize="11"
                               Margin="15,5,0,5"/>

                        <Button x:Name="btnUsers" 
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="15,10"
                            HorizontalAlignment="Stretch" Click="btnUsers_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="👥" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Управление пользователями" FontSize="13" Foreground="#D8BFD8"/>
                            </StackPanel>
                        </Button>

                        <Button x:Name="btnSettings" 
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            Padding="15,10"
                            HorizontalAlignment="Stretch" Click="btnSettings_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🔧" FontSize="14" Margin="0,0,10,0"/>
                                <TextBlock Text="Настройки системы" FontSize="13" Foreground="#D8BFD8"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>




                    <!-- Кнопка выхода внизу -->

                </StackPanel>
                <Border Background="#AD1457" Padding="10" Margin="0,10,0,0" VerticalAlignment="Bottom" Grid.Row="1">
                    <Button x:Name="btnLogout" 
            Background="#E74C3C"
            Foreground="White"
            Padding="10,8"
            BorderThickness="0"
            Cursor="Hand"
            FontSize="13" Click="btnLogout_Click">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                    <ContentPresenter HorizontalAlignment="Center" Margin="10,8"/>
                                </Border>
                            </ControlTemplate>
                        </Button.Template>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🚪" Margin="0,0,8,0"/>
                            <TextBlock Text="Выйти из системы"/>
                        </StackPanel>
                    </Button>
                </Border>
            </Grid>
        </Border>



        <!-- ==================== ВЕРХНЯЯ ПАНЕЛЬ ==================== -->
        <Border Grid.Row="0" Grid.Column="1" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
            <Grid Margin="15,0">
                <!-- Заголовок текущей страницы -->
                <TextBlock x:Name="txtPageTitle" 
                           Text="Главная" 
                           FontSize="18" 
                           FontWeight="SemiBold"
                           Foreground="#2C3E50"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Left"/>

                <!-- Правая панель с уведомлениями и пользователем -->
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <!-- Иконка уведомлений -->
                    <Button x:Name="btnNotifications" 
                            Width="35" 
                            Height="35"
                            Margin="0,0,10,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Cursor="Hand"
                            ToolTip="Уведомления" Click="btnNotifications_Click">
                        <TextBlock Text="🔔" FontSize="18"/>
                    </Button>

                    <!-- Информация о пользователе -->
                    <Border Background="#e44b8d" CornerRadius="20" Padding="10,5,15,5" Margin="0,5,0,5">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="👤" FontSize="14" Margin="0,0,8,0"/>
                            <TextBlock x:Name="txtHeaderUserName" 
                                       Text="Иванов Иван" 
                                       Foreground="White" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text=" (" Foreground="#7F8C8D"/>
                            <TextBlock x:Name="txtHeaderUserRole" 
                                       Text="Админ" 
                                       Foreground="#F1C40F" 
                                       FontWeight="Bold"/>
                            <TextBlock Text=")" Foreground="#7F8C8D"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ==================== ОСНОВНОЕ СОДЕРЖИМОЕ ==================== -->
        <Border Grid.Row="1" Grid.Column="1" Background="#F5F7FA" Padding="15">
            <Frame x:Name="contentControl">
                <Frame.Content>
                    
                
                <!-- Содержимое меняется при нажатии на пункты меню -->
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Добро пожаловать в АРМ Систему!" 
                               FontSize="24" 
                               Foreground="#2C3E50"
                               HorizontalAlignment="Center"/>
                    <TextBlock Text="Выберите раздел из меню слева" 
                               FontSize="14" 
                               Foreground="#7F8C8D"
                               HorizontalAlignment="Center"
                               Margin="0,10,0,0"/>
                </StackPanel>
                </Frame.Content>
            </Frame>
        </Border>

        <!-- ==================== СТАТУСНАЯ СТРОКА ==================== -->
        <Border Grid.Row="2" Grid.Column="1" Background="#7f3667">
            <Grid Margin="15,0">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                    <TextBlock Text="✅ " Foreground="#27AE60"/>
                    <TextBlock x:Name="txtStatus" 
                               Text="Готов к работе" 
                               Foreground="#BDC3C7" 
                               FontSize="11"/>
                </StackPanel>


                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <TextBlock Text="🕐 " Foreground="#7F8C8D" FontSize="11"/>
                    <TextBlock x:Name="txtCurrentTime" 
                               Text="00:00:00" 
                               Foreground="#BDC3C7" 
                               FontSize="11"
                               Margin="0,0,15,0"/>


                    <TextBlock Text="🔄 " Foreground="#7F8C8D" FontSize="11"/>
                    <TextBlock Text="База данных: " Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock x:Name="txtDbStatus" 
                               Text="Подключена" 
                               Foreground="#27AE60" 
                               FontSize="11"
                               FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
