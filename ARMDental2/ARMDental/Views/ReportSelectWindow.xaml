<Window x:Class="ARMDental.Views.ReportSelectWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ARMDental.Views"
        mc:Ignorable="d"
        Title="ReportSelectWindow" Height="450" Width="800" WindowStartupLocation="CenterOwner"> 
    <Grid Margin="20">

        <StackPanel>

            <TextBlock Text="Тип отчёта"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <ComboBox x:Name="cmbReportType"
                      Height="35"
                      Margin="0,0,0,15">

                <ComboBoxItem Content="Количество пациентов за месяц"/>
                <ComboBoxItem Content="Прибыль за месяц"/>

            </ComboBox>

            <TextBlock Text="Выберите месяц и год"
                       FontWeight="Bold"
                       Margin="0,0,0,10"/>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">

                <ComboBox x:Name="cmbMonth"
              Width="180"
              Height="35"
              Margin="0,0,10,0">

                    <ComboBoxItem Content="Январь"/>
                    <ComboBoxItem Content="Февраль"/>
                    <ComboBoxItem Content="Март"/>
                    <ComboBoxItem Content="Апрель"/>
                    <ComboBoxItem Content="Май"/>
                    <ComboBoxItem Content="Июнь"/>
                    <ComboBoxItem Content="Июль"/>
                    <ComboBoxItem Content="Август"/>
                    <ComboBoxItem Content="Сентябрь"/>
                    <ComboBoxItem Content="Октябрь"/>
                    <ComboBoxItem Content="Ноябрь"/>
                    <ComboBoxItem Content="Декабрь"/>

                </ComboBox>

                <ComboBox x:Name="cmbYear"
              Width="100"
              Height="35"/>

            </StackPanel>

            <Button Content="📊 Выгрузить в Excel"
                    Height="40"
                    Background="#27AE60"
                    Foreground="White"
                    Click="btnExport_Click"/>

        </StackPanel>

    </Grid>
</Window>
