<Window x:Class="ARMDental.Views.VisitEditForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Приём"
        Height="943" 
        Width="455"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#c2185b" Padding="15" Margin="-20,-20,-20,15">
            <TextBlock x:Name="txtTitle" Text="Новый приём"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Пациент *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbPatient" Height="35" Margin="0,0,0,15" DisplayMemberPath="DisplayName"/>
            <TextBox x:Name="txtNewPatient" Height="35" Margin="0,-10,0,15" Padding="10,5" 
                     Visibility="Collapsed"/>

            <TextBlock Text="Врач *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbDoctor" Height="35" Margin="0,0,0,15" DisplayMemberPath="DisplayName"/>

            <TextBlock Text="Дата и время приёма *" FontWeight="Bold" Margin="0,0,0,5"/>
            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="100"/>
                </Grid.ColumnDefinitions>
                <DatePicker x:Name="dpDate" Grid.Column="0" Height="35"/>
                <TextBox x:Name="txtTime" Grid.Column="2" Height="35" Padding="10,5" 
                         Text="09:00" TextAlignment="Center"/>
            </Grid>

            <TextBlock Text="Статус" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbStatus" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="Услуги" FontWeight="Bold" Margin="0,10,0,5"/>

            <ListBox x:Name="lstServices" Height="120"
                     SelectionMode="Multiple"
                     DisplayMemberPath="Name"/>
            <TextBlock Text="Диагнозы" FontWeight="Bold" Margin="0,10,0,5"/>

            <ListBox x:Name="lstDiagnoses" Height="100" SelectionMode="Multiple" DisplayMemberPath="Name"/>

            <TextBlock Text="Заметки" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtNotes" Height="80" Margin="0,0,0,15" Padding="10,5"
                     TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" 
                    Width="120" Height="35" 
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" 
                    Width="100" Height="35" 
                    Background="#95A5A6" Foreground="White"
                    BorderThickness="0"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
