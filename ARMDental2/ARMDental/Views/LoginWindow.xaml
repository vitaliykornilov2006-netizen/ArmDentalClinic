<Window x:Class="ARMDental.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ARMDental.Views"
        mc:Ignorable="d"
        Title="Вход в систему" Height="600" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Window.Resources>
        <Style TargetType="TextBox" x:Key="LoginTextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>

        <Style TargetType="PasswordBox" x:Key="LoginPasswordBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="0,5,0,15"/>
            <Setter Property="Padding" Value="10,0"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Border Grid.Row="0" Background="#c2185b" Padding="20">
            <TextBlock Text="Вход в систему АРМ"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>
        <StackPanel Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Width="300">

            <!-- Иконка пользователя (опционально) -->
            <TextBlock Text="🔑" 
                       FontSize="48" 
                       HorizontalAlignment="Center"
                       Margin="0,0,0,20"/>

            <!-- Поле Логин -->
            <TextBlock Text="Логин" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtLogin" 
                     Style="{StaticResource LoginTextBox}"/>

            <!-- Поле Пароль -->
            <TextBlock Text="Пароль" FontWeight="Bold" Margin="0,0,0,5"/>
            <PasswordBox x:Name="txtPassword" 
                         Style="{StaticResource LoginPasswordBox}"/>

            <!-- Сообщение об ошибке -->
            <TextBlock x:Name="txtError" 
                       Foreground="Red" 
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       MinHeight="20"/>

            <!-- Кнопки -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20,0,0">
                <Button x:Name="btnLogin" 
                        Content="Вход"
                        Click="btnLogin_Click"
                        Background="#27AE60" 
                        Foreground="White"
                        Width="100" 
                        Height="35"
                        Margin="0,0,10,0"/>

                <Button x:Name="btnCancel" 
                        Content="Отмена"
                        Click="btnCancel_Click"
                        Background="#E74C3C" 
                        Foreground="White"
                        Width="100" 
                        Height="35"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
