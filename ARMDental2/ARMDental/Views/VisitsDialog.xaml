<Page x:Class="ARMDental.Views.VisitsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
         xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
         xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
         xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
         xmlns:local="clr-namespace:ARMDental.Views"
         mc:Ignorable="d" 
        d:DesignHeight="850" d:DesignWidth="1200"
        Title="Приёмы — АРМ Стоматологическая клиника"
        Background="#F5F7FA">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#ECF0F1" BorderBrush="#BDC3C7" BorderThickness="0,0,0,1">
            <Grid Margin="20,14">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="📋" FontSize="29" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Приёмы" FontSize="24" FontWeight="SemiBold" Foreground="#2C3E50"/>
                        <TextBlock Text="Журнал посещений пациентов" FontSize="13.5" Foreground="#7F8C8D"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button x:Name="btnNewVisit" Background="#c2185b" Foreground="White" Padding="18,9" Margin="0,0,8,0" Click="btnNewVisit_Click">➕ Новый приём</Button>
                    <Button x:Name="btnEdit" Background="#f39c12" Foreground="White" Padding="18,9" Margin="0,0,8,0" Click="btnEdit_Click">✏️ Изменить</Button>
                    <Button x:Name="btnDelete" Background="#e74c3c" Foreground="White" Padding="18,9" Margin="0,0,8,0" Click="btnDelete_Click">🗑 Удалить</Button>
                    <Button x:Name="btnRefresh" Background="White" BorderBrush="#BDC3C7" Padding="16,9" Click="btnRefresh_Click">🔄 Обновить</Button>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Background="#F5F7FA" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Фильтры -->
                <Border Background="White"
                CornerRadius="8"
                Padding="15"
                Margin="0,0,0,15"
                BorderBrush="#E5E7EB"
                BorderThickness="1">

                    <StackPanel>

                        <!-- Первая строка -->
                        <WrapPanel Margin="0,0,0,10">

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Пациент" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtPatientSearch"
                                 Width="180"
                                 Height="35"
                                 Padding="10,5"
                                 TextChanged="Filters_Changed"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Врач" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtDoctorSearch"
                                 Width="180"
                                 Height="35"
                                 Padding="10,5"
                                 TextChanged="Filters_Changed"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Услуга" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtServiceSearch"
                                 Width="180"
                                 Height="35"
                                 Padding="10,5"
                                 TextChanged="Filters_Changed"/>
                            </StackPanel>

                            <StackPanel>
                                <TextBlock Text="Диагноз" Margin="0,0,0,4"/>
                                <TextBox x:Name="txtDiagnosisSearch"
                                 Width="180"
                                 Height="35"
                                 Padding="10,5"
                                 TextChanged="Filters_Changed"/>
                            </StackPanel>

                        </WrapPanel>

                        <!-- Вторая строка -->
                        <WrapPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Дата" Margin="0,0,0,4"/>
                                <DatePicker x:Name="dpDateFilter" 
                                            SelectedDateChanged="Filters_Changed"
                                            Width="160"/>
                            </StackPanel>

                            <StackPanel Margin="0,0,15,0">
                                <TextBlock Text="Статус" Margin="0,0,0,4"/>
                                <ComboBox x:Name="cmbStatusFilter"
                                  Width="200"
                                  Height="35"
                                  SelectionChanged="Filters_Changed">
                                    <ComboBoxItem Content="Все статусы" IsSelected="True"/>
                                    <ComboBoxItem Content="Запланирована"/>
                                    <ComboBoxItem Content="В процессе"/>
                                    <ComboBoxItem Content="Завершена"/>
                                    <ComboBoxItem Content="Отменена"/>
                                </ComboBox>
                            </StackPanel>

                            <Button Content="Сбросить"
                            Width="120"
                            Height="35"
                            Margin="10,22,0,0"
                            Background="#95A5A6"
                            Foreground="White"
                            Click="btnClearFilters_Click"/>

                        </WrapPanel>

                    </StackPanel>
                </Border>

                <!-- Таблица -->
                <DataGrid x:Name="dgVisits"
                  Grid.Row="1"
                  Background="White"
                  RowHeight="52"
                  HeadersVisibility="Column"
                  GridLinesVisibility="None"
                  BorderBrush="#E5E7EB"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"/>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#7f3667" Height="34">
            <Grid Margin="20,0">
                <TextBlock x:Name="txtCount" Text="Приёмов сегодня: 0" Foreground="#F0E6EA" VerticalAlignment="Center" FontSize="13"/>
            </Grid>
        </Border>
    </Grid>
</Page>
