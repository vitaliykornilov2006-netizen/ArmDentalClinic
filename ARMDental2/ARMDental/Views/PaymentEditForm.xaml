<Window x:Class="ARMDental.Views.PaymentEditForm"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Оплата"
        Height="550" 
        Width="450"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F7FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->
        <Border Grid.Row="0" Background="#c2185b" Padding="15" Margin="-20,-20,-20,15">
            <TextBlock x:Name="txtTitle" Text="Новая оплата"
                       FontSize="18" FontWeight="Bold" Foreground="White"/>
        </Border>

        <!-- Форма -->
        <StackPanel Grid.Row="1">
            <TextBlock Text="Приём *" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbAppointment" Height="35" Margin="0,0,0,15" 
                      DisplayMemberPath="DisplayText"/>

            <TextBlock Text="Сумма (₽) *" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="txtAmount" Height="35" Margin="0,0,0,15" Padding="10,5"/>

            <TextBlock Text="Метод оплаты" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbPayMethod" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="Дата оплаты *" FontWeight="Bold" Margin="0,0,0,5"/>
            <DatePicker x:Name="dpPayDate" Height="35" Margin="0,0,0,15"/>

            <TextBlock Text="Статус" FontWeight="Bold" Margin="0,0,0,5"/>
            <ComboBox x:Name="cmbStatus" Height="35" Margin="0,0,0,15"/>
        </StackPanel>

        <!-- Кнопки -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="💾 Сохранить" 
                    Width="120" Height="35" 
                    Background="#27AE60" Foreground="White"
                    BorderThickness="0" Margin="0,0,10,0"
                    Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" 
                    Width="100" Height="35" 
                    Background="#95A5A6" Foreground="White"
                    BorderThickness="0"
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
